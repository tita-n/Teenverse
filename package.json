{
  "name": "teenverse",
  "version": "1.0.0",
  "description": "TeenVerse: Teen-only social media with coins, hype, and chaos.",
  "main": "backend/server.ts",
  "scripts": {
    "start": "ts-node backend/server.ts",
    "start:prod": "node dist/server.js",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm install && vite build",
    "dev": "concurrently \"npm run start\" \"npm run client\"",
    "dev:backend": "nodemon --exec ts-node backend/server.ts",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "echo \"No tests configured yet\" && exit 0",
    "docker:build": "docker build -t teenverse-backend .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [],
  "author": "Titan & Sol",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.0",
    "cors": "^2.8.5",
    "dompurify": "^3.0.8",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.22.3",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.5",
    "multer": "^1.4.5-lts.1",
    "react-chartjs-2": "^5.2.0",
    "chart.js": "^4.4.0",
    "lucide-react": "^0.453.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/dotenv": "^8.2.0",
    "@vitejs/plugin-react": "^4.1.0",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.16",
    "@types/multer": "^1.4.12",
    "@types/react-helmet": "^6.1.6"
  }
}
