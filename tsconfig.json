{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "rootDir": "./backend",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true, 
    "typeRoots": ["./backend/types", "./node_modules/@types"]
  },
  "include": ["backend/**/*", "types/**/*"],
  "exclude": ["node_modules", "dist"]
}
