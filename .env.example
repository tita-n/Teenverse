# ================================
# Teenverse Environment Variables
# ================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===== Server Configuration =====
NODE_ENV=development
PORT=5000

# ===== Security (REQUIRED) =====
# Generate a strong random key with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=generate_a_64_character_hex_string_here

# ===== Admin Configuration =====
# The email address that has admin privileges on the platform
ADMIN_EMAIL=your_admin_email@example.com

# ===== Database - Neon PostgreSQL (REQUIRED) =====
# Get your connection string from https://neon.tech dashboard
DATABASE_URL=postgresql://username:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/teenverse?sslmode=require

# ===== Cloudinary (Media Storage) =====
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===== CORS Configuration =====
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://teenverse.onrender.com

# ===== Frontend (for builds) =====
VITE_API_URL=http://localhost:5000
